# This file is generated by react-native and should be checked into source control.
# It contains the path to the Node.js executable used to run Metro.
#
# If your team uses a Node version manager (nvm, fnm, volta) add a .xcode.env.local
# with the correct path; that file is gitignored.
#
# Common paths:
#   Homebrew (Apple Silicon): /opt/homebrew/bin/node
#   Homebrew (Intel):         /usr/local/bin/node
#   nvm default:              $HOME/.nvm/versions/node/$(nvm version)/bin/node
#   volta:                    $HOME/.volta/bin/node
#
# To generate automatically:
#   echo export NODE_BINARY=$(command -v node) > .xcode.env.local

export NODE_BINARY=$(command -v node)

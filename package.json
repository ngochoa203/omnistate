{
  "name": "omnistate",
  "version": "0.1.0",
  "private": true,
  "description": "Shadow OS — an invisible system administrator that autonomously operates your computer",
  "repository": "https://github.com/ngochoa203/omnistate",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:native": "cargo build -p omnistate-napi --release && node scripts/copy-native.mjs",
    "dev": "pnpm -r --filter @omnistate/gateway dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r clean && cargo clean",
    "repl": "node packages/gateway/scripts/test-repl.mjs",
    "start": "node packages/gateway/dist/index.js",
    "web": "cd packages/web && pnpm dev",
    "run:all": "node scripts/run-all.mjs",
    "run:all:one-port": "node scripts/run-all.mjs",
    "usecase:report": "node scripts/usecase-report.mjs",
    "test:planner": "pnpm --filter @omnistate/gateway test:planner"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}

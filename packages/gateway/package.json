    "test:planner": "vitest run src/__tests__/planner.test.ts --testTimeout=30000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "json5": "^2.2.3",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"

{
  "name": "@omnistate/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OmniState gateway daemon — task planning, execution orchestration, session management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",

# Required for whisper-cloud STT transcription (leave blank to use whisper-local)
OPENAI_API_KEY=

# Port the gateway listens on (default: 19800)
GATEWAY_PORT=19800

# Anthropic API key for LLM-backed planning and execution
ANTHROPIC_API_KEY=
# Override Anthropic API base URL (optional, e.g. proxy endpoint)
ANTHROPIC_BASE_URL=
# Anthropic model to use (optional, defaults to config value)
ANTHROPIC_MODEL=

# JWT secret for authenticating gateway clients
OMNISTATE_JWT_SECRET=

# Comma-separated list of allowed CORS origins
OMNISTATE_ALLOWED_ORIGINS=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Set to "1" to skip LLM auth requirement on startup
OMNISTATE_REQUIRE_LLM=

# TTS provider: edge-tts | rtvc | system (default per config)
OMNISTATE_TTS_PROVIDER=

# Porcupine wake-word access key (required for hardware wake-word detection)
PORCUPINE_ACCESS_KEY=
# Path to custom Porcupine keyword file (.ppn)
OMNISTATE_PORCUPINE_KEYWORD_PATH=

# Set to "1" to enable speaker verification
OMNISTATE_SPEAKER_VERIFY_ENABLED=

# 9router fallback proxy base URL and credentials (optional)
OMNISTATE_ROUTER9_BASE_URL=
OMNISTATE_ROUTER9_API_KEY=
OMNISTATE_ROUTER9_MODEL=

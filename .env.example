# OmniState Environment Configuration

# LLM API (required for vision + intent classification)
ANTHROPIC_API_KEY=sk-your-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: OpenAI-compatible endpoint
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Gateway
OMNISTATE_PORT=19800
OMNISTATE_BIND=127.0.0.1

# MiniMax LLM API (used as the primary provider in default config)
# Obtain from https://www.minimax.io
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# Voice Pipeline
VOICE_STT_PROVIDER=whisper-local
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
VAD_ENABLED=true
VAD_SILENCE_THRESHOLD_MS=400
OMNISTATE_WAKE_PYTHON=
WAKE_ENGINE=openwakeword
OMNISTATE_SIRI_ENDPOINT=http://127.0.0.1:19801/siri/command
VAD_PROVIDER=silero

